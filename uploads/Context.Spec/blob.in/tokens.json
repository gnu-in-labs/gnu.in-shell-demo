{
  "$schema": "https://gnu-in-labs.dev/schemas/tokens-1.json",
  "version": "0.4.0",
  "comment": "Single source of truth for Gnu.In-Shell motion + colour tokens. Codegen targets: blobin_tokens.rs (Rust solver), gnu_theme.qml/.h/.dart (existing). Regenerate: blobin-gen tokens.json --rust ../blobin-core/src/tokens.rs",

  "motion": {
    "durations_ms": {
      "instant": 90,
      "quick": 160,
      "base": 240,
      "calm": 380,
      "slow": 560,
      "breathe": 4200
    },
    "eases": {
      "enter":  { "p1x": 0.2,  "p1y": 0.8,  "p2x": 0.2,  "p2y": 1.0 },
      "exit":   { "p1x": 0.4,  "p1y": 0.0,  "p2x": 1.0,  "p2y": 1.0 },
      "inout":  { "p1x": 0.45, "p1y": 0.05, "p2x": 0.55, "p2y": 0.95 },
      "bloom":  { "p1x": 0.34, "p1y": 1.56, "p2x": 0.64, "p2y": 1.0 }
    },
    "springs": {
      "settle": { "stiffness": 170.0, "damping": 22.0, "mass": 1.0 },
      "snap":   { "stiffness": 260.0, "damping": 24.0, "mass": 1.0 },
      "wobbly": { "stiffness": 200.0, "damping": 12.0, "mass": 1.0 }
    }
  },

  "color": {
    "accent":     "#FF6A00",
    "surface":    "#F7F3ED",
    "ink":        "#111418",
    "ink_dim":    "#2B3037",
    "transmit":   "#5F7F52",
    "info":       "#3D8DCC",
    "rust":       "#CE8E3F"
  }
}
