    { "state": "listening", "mode": "loop",     "dur_ms": 1400, "screen_glyph": "prompt + three dots",            "visual": "chevron stable · dots breathe · antenna rings", "motion": "subtle micro-lean",    "syster": "listening" },
    { "state": "thinking",  "mode": "loop",     "dur_ms": 1200, "screen_glyph": "prompt → ·→··→···→··→ prompt",   "visual": "chevron stable · dot sequence · screen-only",   "motion": "body calm",            "syster": "work",  "frame_ms": 200 },
    { "state": "success",   "mode": "one-shot", "dur_ms": 520,  "screen_glyph": "prompt-success",                 "visual": "green underscore + screen-local glow",        "motion": "positive bounce on rig", "syster": "success" },
    { "state": "error",     "mode": "one-shot", "dur_ms": 520,  "screen_glyph": "error",                          "visual": "red mark + red underscore + antenna ticks",   "motion": "recoil on rig",          "syster": "fail" }
